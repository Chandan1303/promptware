# ==================================================
# EcoGuide AI - Environment Variables Template
# ==================================================
# Copy this file to .env and fill in your API keys
# Never commit your actual .env file to version control
# ==================================================

# ===== GOOGLE GEMINI AI API =====
# Get your key from: https://aistudio.google.com/apikey
# Used for: AI sustainability coaching and personalized recommendations
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ===== GOOGLE ANALYTICS 4 =====
# Get your Measurement ID from: Google Analytics → Admin → Data Streams
# Used for: User engagement tracking and analytics
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===== GOOGLE MAPS API =====
# Get from: https://console.cloud.google.com/google/maps-apis
# Used for: Transportation carbon tracking and route optimization
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ===== GOOGLE TRANSLATE API =====
# Get from: https://console.cloud.google.com/apis/library/translate.googleapis.com
# Used for: Multi-language support (i18n)
VITE_GOOGLE_TRANSLATE_API_KEY=your_translate_api_key_here

# ===== GOOGLE CLOUD VISION API =====
# Get from: https://console.cloud.google.com/apis/library/vision.googleapis.com
# Used for: Receipt/document analysis for carbon tracking
VITE_GOOGLE_VISION_API_KEY=your_vision_api_key_here

# ===== GOOGLE RECAPTCHA v3 =====
# Get from: https://www.google.com/recaptcha/admin
# Used for: Bot protection and security
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# ===== GOOGLE CLOUD STORAGE (Optional) =====
# Get from: https://console.cloud.google.com/storage
# Used for: Storing user-uploaded images and documents
VITE_GCS_BUCKET_NAME=your_bucket_name
VITE_GCS_PROJECT_ID=your_project_id

# ==================================================
# NOTES:
# - App works in demo/simulation mode without API keys
# - All data is stored locally in browser (LocalStorage)
# - No Firebase or backend database required
# - All Google Cloud APIs are optional but enhance functionality
# - Gemini AI provides best experience but has intelligent fallback
# ==================================================
